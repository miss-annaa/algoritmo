programa {
  funcao inicio() {
    
    caracter select

    escreva("digite uma uma letra: ")
    leia(select)
     
    escolha(select) {
      caso 'Z':
      {
        escreva("seu vigor foi aumentado em 35%")
       pare 
      }
      caso 'X':
      {
       escreva("você recolheu o charope de suas plantas")
       pare
     }
     caso 'K':
     {
      escreva("você morreu")
      pare
     }
     caso contrario:
     {

     }
   }
   
  }
}
