programa {
  funcao inicio() {
     inteiro mana

     escreva("você é um mago muito poderoso e está aprendendo um novo feitiço, quanto de mana você liberou:")
     leia(mana)

     se (mana <= 20){
     escreva("pouca liberação, fez apenas uma faisca")
     }
     senao se(mana >=30 ){
      escreva("você fez uma mega explosão:o")
     }
  
  }
}
